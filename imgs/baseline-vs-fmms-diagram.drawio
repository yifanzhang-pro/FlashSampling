<mxfile host="app.diagrams.net">
  <diagram name="FMMS vs Baseline" id="d1">
    <mxGraphModel dx="900" dy="650" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="820" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Divider -->
        <mxCell id="divider" value="" style="endArrow=none;dashed=1;strokeColor=#E0E0E0;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="380" y="10" as="sourcePoint"/>
            <mxPoint x="380" y="540" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== LEFT: Multinomial Sampling ===== -->

        <mxCell id="L_title" value="&lt;b&gt;Multinomial Sampling&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="95" y="10" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- Inputs -->
        <mxCell id="L_W" value="W ∈ [V,d]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="60" width="110" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="L_H" value="H ∈ [N,d]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="210" y="60" width="110" height="36" as="geometry"/>
        </mxCell>

        <!-- Ops -->
        <mxCell id="L_matmul" value="Matmul (cuBLAS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="110" y="125" width="170" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="L_softmax" value="Softmax" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="110" y="219" width="170" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="L_multinomial" value="Multinomial" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="110" y="313" width="170" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="L_samples" value="Samples ∈ [N,1]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="110" y="387" width="170" height="44" as="geometry"/>
        </mxCell>

        <!-- Edges: inputs to matmul -->
        <mxCell id="E_LW" value="" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;" edge="1" source="L_W" target="L_matmul" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="E_LH" value="" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;" edge="1" source="L_H" target="L_matmul" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Matmul to Softmax (Logits) -->
        <mxCell id="E_L_logits" value="Logits ∈ [N,V]" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;fontSize=13;fontColor=#C62828;" edge="1" source="L_matmul" target="L_softmax" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Softmax to Multinomial (Probs) -->
        <mxCell id="E_L_probs" value="Probs ∈ [N,V]" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;fontSize=13;fontColor=#C62828;" edge="1" source="L_softmax" target="L_multinomial" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Multinomial to Samples -->
        <mxCell id="E_L_out" value="" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;" edge="1" source="L_multinomial" target="L_samples" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>


        <!-- ===== RIGHT: FMMS ===== -->

        <mxCell id="R_title" value="&lt;b&gt;FMMS&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="460" y="10" width="180" height="35" as="geometry"/>
        </mxCell>

        <!-- Inputs -->
        <mxCell id="R_W" value="W ∈ [V,d]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="435" y="60" width="110" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="R_H" value="H ∈ [N,d]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="565" y="60" width="110" height="36" as="geometry"/>
        </mxCell>

        <!-- SHMEM region (behind the ops) -->
        <mxCell id="R_shmem" value="&lt;b&gt;SHMEM&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;strokeWidth=2;dashed=1;dashPattern=8 4;opacity=40;verticalAlign=bottom;align=right;fontSize=14;fontColor=#2E7D32;spacingBottom=8;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="455" y="112" width="200" height="280" as="geometry"/>
        </mxCell>

        <!-- Ops -->
        <mxCell id="R_matmul" value="Tile Matmul" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4CAF50;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="470" y="130" width="170" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="R_gumbel" value="Add Gumbel Noise" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4CAF50;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="470" y="224" width="170" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="R_argmax" value="Stage I argmax" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4CAF50;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="470" y="318" width="170" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="R_global" value="Stage II argmax" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="470" y="440" width="170" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="R_samples" value="Samples ∈ [N,1]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="470" y="514" width="170" height="44" as="geometry"/>
        </mxCell>

        <!-- Edges: inputs to Tile Matmul -->
        <mxCell id="E_RW" value="" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;" edge="1" source="R_W" target="R_matmul" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="E_RH" value="" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;" edge="1" source="R_H" target="R_matmul" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Tile Matmul to +Gumbel (Logits tile) -->
        <mxCell id="E_R_logits" value="Logits tile" style="endArrow=classic;html=1;strokeColor=#4CAF50;strokeWidth=2;fontSize=13;fontColor=#2E7D32;" edge="1" source="R_matmul" target="R_gumbel" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- +Gumbel to Tile argmax (Noised logits) -->
        <mxCell id="E_R_noised" value="Noised logits" style="endArrow=classic;html=1;strokeColor=#4CAF50;strokeWidth=2;fontSize=13;fontColor=#2E7D32;" edge="1" source="R_gumbel" target="R_argmax" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Tile argmax to Global argmax (Tile-wise argmax) -->
        <mxCell id="E_R_tilemax" value="Tile-wise argmax" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;fontSize=13;fontColor=#C62828;" edge="1" source="R_argmax" target="R_global" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Global argmax to Samples -->
        <mxCell id="E_R_out" value="" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;" edge="1" source="R_global" target="R_samples" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Loop arrow: argmax to Tile Matmul (via right side) -->
        <mxCell id="E_loop" value="For Each Tile" style="endArrow=classic;html=1;strokeColor=#999999;edgeStyle=orthogonalEdgeStyle;curved=0;fontSize=13;fontColor=#999999;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="R_argmax" target="R_matmul" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint as="offset" x="15" y="0"/>
            <Array as="points">
              <mxPoint x="700" y="340"/>
              <mxPoint x="700" y="152"/>
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
